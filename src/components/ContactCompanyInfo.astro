---
import { companyInfo } from '../data/contacts';

const blocks = [
  companyInfo.headquarters,
  companyInfo.bank,
  companyInfo.operations,
  companyInfo.technicalOffice,
];
---

<div class="grid grid-cols-1 gap-x-8 gap-y-8 text-center text-base font-medium leading-relaxed text-navy/90 sm:gap-x-12 sm:gap-y-10 sm:text-lg md:grid-cols-2 lg:text-[21px]">
  {
    blocks.map((block) => (
      <div>
        <h2 class="font-semibold text-navy mb-2">{block.title}</h2>
        {block.lines.map((line) => (
          <p>{line}</p>
        ))}
      </div>
    ))
  }
</div>
