---
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Domů' },
  { href: '/o-nas', label: 'O nás' },
  { href: '/sluzby', label: 'Služby' },
  { href: '/projekty', label: 'Projekty' },
  { href: '/kontakt', label: 'Kontakt' },
];

const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="w-full">
  <div class="mx-auto max-w-site px-6 lg:px-10">
    <nav class="flex min-w-0 items-center justify-between gap-3 py-5 sm:gap-4" aria-label="Hlavní navigace">
      <a href="/" class="shrink-0">
        <img
          src="/images/logo.png"
          alt="PROKAT invest"
          class="h-12 w-auto sm:h-14 lg:h-[60px]"
          width="322"
          height="80"
        />
      </a>

      <ul class="hidden lg:flex items-center gap-9 text-base lg:text-[17px] font-medium text-navy">
        {
          navItems.map((item) => (
            <li>
              {isActive(item.href) ? (
                <a
                  href={item.href}
                  class="inline-flex items-center gap-2 text-navy hover:text-gold-bright transition-colors"
                  aria-current="page"
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-navy" aria-hidden="true" />
                  {item.label}
                </a>
              ) : (
                <a href={item.href} class="text-navy/80 hover:text-gold-bright transition-colors">
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      <a
        href="/kontakt"
        class="btn-gradient hidden lg:inline-flex items-center gap-2.5 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-5 pr-1 py-2 text-white text-base font-medium min-h-[56px] h-auto hover:opacity-95 transition-opacity shrink-0"
      >
        <span>Získejte CN</span>
        <span
          class="btn-gradient-icon flex h-11 w-11 shrink-0 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
        >
          <img src="/icons/arrow.svg" alt="" class="h-3.5 w-4" width="16" height="12" />
        </span>
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Otevřít menu"
        aria-expanded="false"
      >
        <span class="block h-0.5 w-6 bg-navy"></span>
        <span class="block h-0.5 w-6 bg-navy"></span>
        <span class="block h-0.5 w-6 bg-navy"></span>
      </button>
    </nav>

    <div id="mobile-menu" class="hidden lg:hidden pb-6 border-t border-gray-200">
      <ul class="flex flex-col gap-4 pt-4 text-base font-medium text-navy">
        {
          navItems.map((item) => (
            <li>
              {isActive(item.href) ? (
                <a
                  href={item.href}
                  class="inline-flex items-center gap-2 hover:text-gold-bright transition-colors"
                  aria-current="page"
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-navy" aria-hidden="true" />
                  {item.label}
                </a>
              ) : (
                <a href={item.href} class="hover:text-gold-bright transition-colors">
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isHidden));
  });
</script>
