---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Domů' },
  { href: '/o-nas', label: 'O nás' },
  { href: '/sluzby', label: 'Služby' },
  { href: '/projekty', label: 'Projekty' },
  { href: '/kontakt', label: 'Kontakt' },
];

const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(`${href}/`);
---

<header
  class:list={[
    'mobile-nav-gradient relative z-50 w-full',
    transparent && 'lg:absolute lg:inset-x-0 lg:top-0 lg:bg-transparent',
  ]}
>
  <div class="mx-auto max-w-site px-6 lg:px-10">
    <nav class="relative flex min-h-[60px] items-center lg:min-h-0 lg:justify-between lg:py-5" aria-label="Hlavní navigace">
      <a
        href="/"
        class="absolute left-1/2 z-10 -translate-x-1/2 lg:static lg:translate-x-0 lg:shrink-0"
      >
        <img
          src="/images/logo.png"
          alt="PROKAT invest"
          class="h-11 w-auto sm:h-12 lg:h-[60px]"
          width="322"
          height="80"
        />
      </a>

      <ul class="hidden lg:flex items-center gap-9 text-base lg:text-[17px] font-medium text-navy">
        {
          navItems.map((item) => (
            <li>
              {isActive(item.href) ? (
                <a
                  href={item.href}
                  class="inline-flex items-center gap-2 text-navy hover:text-gold-bright transition-colors"
                  aria-current="page"
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-navy" aria-hidden="true" />
                  {item.label}
                </a>
              ) : (
                <a href={item.href} class="text-navy/80 hover:text-gold-bright transition-colors">
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      <a
        href="/kontakt"
        class="btn-gradient hidden lg:inline-flex items-center gap-2.5 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-5 pr-1 py-2 text-white text-base font-medium min-h-[56px] h-auto hover:opacity-95 transition-opacity shrink-0"
      >
        <span>Získejte CN</span>
        <span
          class="btn-gradient-icon flex h-11 w-11 shrink-0 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
        >
          <img src="/icons/arrow.svg" alt="" class="h-3.5 w-4" width="16" height="12" />
        </span>
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="ml-auto flex h-10 w-10 flex-col items-center justify-center gap-[5px] rounded-lg bg-[#0a0812]/95 p-2 lg:hidden"
        aria-label="Otevřít menu"
        aria-expanded="false"
      >
        <span class="block h-[2px] w-5 rounded-full bg-white"></span>
        <span class="block h-[2px] w-5 rounded-full bg-white"></span>
      </button>
    </nav>

    <div
      id="mobile-menu"
      class="hidden border-t border-white/15 pb-6 lg:hidden"
    >
      <ul class="flex flex-col gap-4 pt-4 text-base font-medium text-white/90">
        {
          navItems.map((item) => (
            <li>
              {isActive(item.href) ? (
                <a
                  href={item.href}
                  class="inline-flex items-center gap-2 text-gold-bright transition-colors"
                  aria-current="page"
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-gold-bright" aria-hidden="true" />
                  {item.label}
                </a>
              ) : (
                <a href={item.href} class="hover:text-gold-bright transition-colors">
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</header>

<style>
  .mobile-nav-gradient {
    background: linear-gradient(
      90deg,
      #080810 0%,
      #15101c 14%,
      #3d2e1a 32%,
      #a67c37 50%,
      #3d2e1a 68%,
      #15101c 86%,
      #080810 100%
    );
  }

  @media (min-width: 1024px) {
    .mobile-nav-gradient {
      background: transparent;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isHidden));
  });
</script>
