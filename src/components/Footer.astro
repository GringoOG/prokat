---
const pathname = Astro.url.pathname;

const isActive = (href: string) =>
  href === '/'
    ? pathname === '/'
    : href !== '#' && (pathname === href || pathname.startsWith(`${href}/`));

const footerLinkClass = (href: string) =>
  isActive(href)
    ? 'text-gold-bright transition-colors'
    : 'text-[#a7a3a2] hover:text-gold-bright transition-colors';
---

<footer class="footer-panel relative text-white overflow-hidden">
  <img
    src="/images/footer-watermark.png"
    alt=""
    class="pointer-events-none absolute left-1/2 top-[42%] z-0 w-full max-w-[1200px] -translate-x-1/2 -translate-y-1/2 opacity-[0.12] object-contain select-none"
    aria-hidden="true"
  />

  <div class="relative z-10 mx-auto max-w-site px-6 lg:px-10 py-16 lg:py-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-0">
      <div class="lg:pr-8 xl:pr-12">
        <h2 class="text-xl lg:text-[28px] font-semibold mb-6">Odkazy</h2>
        <ul class="space-y-3 text-base lg:text-[23px] font-medium">
          <li><a href="/" class={footerLinkClass('/')}>Domů</a></li>
          <li><a href="/o-nas" class={footerLinkClass('/o-nas')}>O nás</a></li>
          <li><a href="/sluzby" class={footerLinkClass('/sluzby')}>Služby</a></li>
        </ul>
      </div>

      <div class="lg:px-8 xl:px-12 lg:pt-[3.25rem] xl:pt-[3.75rem]">
        <ul class="space-y-3 text-base lg:text-[23px] font-medium">
          <li><a href="/projekty" class={footerLinkClass('/projekty')}>Projekty</a></li>
          <li><a href="/kontakt" class={footerLinkClass('/kontakt')}>Kontakt</a></li>
          <li><a href="#" class={footerLinkClass('#')}>GDPR</a></li>
        </ul>
      </div>

      <div class="lg:px-8 xl:px-12">
        <h2 class="text-xl lg:text-[28px] font-semibold mb-6">Kontakt</h2>
        <a
          href="https://www.linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 text-base lg:text-[23px] font-medium text-white/90 hover:text-white transition-colors mb-4"
        >
          <img src="/icons/linkedin.png" alt="" class="h-8 w-8 rounded" width="32" height="32" />
          LinkedIn
        </a>
        <p class="text-base lg:text-[23px] font-medium text-white/90 leading-snug">
          <a
            href="https://maps.google.com/?q=Plzeňská+1348/95,+Praha"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors"
          >
            Plzeňská 1348/95, Praha 150 00
          </a>
        </p>
      </div>

      <div class="hidden lg:block" aria-hidden="true"></div>
    </div>
  </div>

  <div class="relative z-10 border-t border-white/10 bg-[#050a14]/80">
    <p class="mx-auto max-w-site px-6 lg:px-10 py-5 text-center text-xs sm:text-sm lg:text-base font-medium text-white/50">
      Copyright © 2026 | PROKAT invest s.r.o. | Všechna práva vyhrazena.
    </p>
  </div>
</footer>

<style>
  .footer-panel {
    background:
      radial-gradient(ellipse 85% 90% at 50% 35%, rgba(180, 130, 55, 0.65) 0%, rgba(100, 72, 38, 0.4) 32%, transparent 68%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(40, 30, 20, 0.9) 0%, transparent 55%),
      linear-gradient(180deg, #0a0812 0%, #15101c 35%, #3d2e1a 55%, #15101c 80%, #080810 100%);
  }
</style>
