---
const visibleProjects = [
  {
    client: 'Škoda Auto',
    subtitle: 'Datové centrum',
    savings: '16%',
    image: '/images/projects/project-skoda.jpg',
    alt: 'Škoda Auto — datové centrum',
  },
  {
    client: 'Pilsner Urquel',
    subtitle: 'Odvětrávání CO2',
    savings: '18%',
    image: '/images/projects/project-pilsner.jpg',
    alt: 'Pilsner Urquel — odvětrávání CO2',
  },
  {
    client: 'Letiště Václava Havla',
    subtitle: 'Strojovna chlazení',
    savings: '17%',
    image: '/images/projects/project-airport.jpg',
    alt: 'Letiště Václava Havla — strojovna chlazení',
  },
  {
    client: 'Hotel Marriott',
    subtitle: 'Chlazení, topení, VZT, TZB, rekonstrukce kotelny i pokojů',
    savings: '12%',
    image: '/images/projects/project-marriott.jpg',
    alt: 'Hotel Marriott',
  },
  {
    client: "King's Casino",
    subtitle: 'Chlazení, topení, VZT, TZB',
    savings: '15%',
    image: '/images/projects/project-casino.jpg',
    alt: "King's Casino",
  },
  {
    client: 'Hotel Epiq',
    subtitle: 'Výstavba kotelny',
    savings: '19%',
    image: '/images/projects/project-epiq.jpg',
    alt: 'Hotel Epiq — výstavba kotelny',
  },
];

const moreProjects = [
  {
    client: 'Košířská brána',
    subtitle: 'Chlazení, topení, VZT, TZB',
    savings: '17%',
    image: '/images/projects/project-kosirska.jpg',
    alt: 'Košířská brána',
  },
  {
    client: 'Lutz',
    subtitle: 'FVE — Čestlice, Plzeň, Letňany, Modřice, Liberec, Stodůlky',
    savings: '20%',
    image: '/images/projects/project-lutz.png',
    alt: 'Lutz — fotovoltaika',
  },
  {
    client: 'Möbelix Liberec',
    subtitle: 'FVE — Liberec',
    savings: '20%',
    image: '/images/projects/project-mobelix.png',
    alt: 'Möbelix Liberec — fotovoltaika',
  },
];
---

<div class="rounded-2xl border border-gold/60 bg-navy p-4 sm:p-6 lg:p-8">
  <div id="projects-grid" class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:gap-6">
    {
      visibleProjects.map((project) => (
        <article class="grid grid-cols-1 overflow-hidden rounded-xl bg-white sm:grid-cols-2">
          <div class="flex min-h-[200px] flex-col justify-center p-6 sm:min-h-[240px] lg:p-8">
            <h2 class="text-xl font-semibold leading-tight text-gold lg:text-2xl">{project.client}</h2>
            <p class="mt-2 text-sm font-medium leading-snug text-navy/70 lg:text-base">{project.subtitle}</p>
            <div class="mt-4 lg:mt-6">
              <p class="text-3xl font-semibold leading-none text-navy lg:text-4xl">{project.savings}</p>
              <p class="mt-1 text-sm font-medium text-navy/60 lg:text-base">Úspora provozních nákladů</p>
            </div>
          </div>
          <div class="relative min-h-[220px] overflow-hidden bg-gray-100 sm:h-full sm:min-h-0">
            <img
              src={project.image}
              alt={project.alt}
              class="absolute inset-0 h-full w-full object-cover object-center"
              loading="lazy"
              decoding="async"
            />
          </div>
        </article>
      ))
    }

    <div id="projects-more" class="contents hidden">
      {
        moreProjects.map((project) => (
          <article class="grid grid-cols-1 overflow-hidden rounded-xl bg-white sm:grid-cols-2">
            <div class="flex min-h-[200px] flex-col justify-center p-6 sm:min-h-[240px] lg:p-8">
              <h2 class="text-xl font-semibold leading-tight text-gold lg:text-2xl">{project.client}</h2>
              <p class="mt-2 text-sm font-medium leading-snug text-navy/70 lg:text-base">{project.subtitle}</p>
              <div class="mt-4 lg:mt-6">
                <p class="text-3xl font-semibold leading-none text-navy lg:text-4xl">{project.savings}</p>
                <p class="mt-1 text-sm font-medium text-navy/60 lg:text-base">Úspora provozních nákladů</p>
              </div>
            </div>
            <div class="relative min-h-[220px] overflow-hidden bg-gray-100 sm:h-full sm:min-h-0">
              <img
                src={project.image}
                alt={project.alt}
                class="absolute inset-0 h-full w-full object-cover object-center"
                loading="lazy"
                decoding="async"
              />
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <div class="mt-8 flex justify-center">
    <button
      id="projects-show-more"
      type="button"
      class="rounded-full bg-gold-bright px-8 py-3 text-sm font-semibold text-navy transition-colors hover:bg-gold"
    >
      Zobrazit více
    </button>
    <p id="projects-coming-soon" class="hidden text-base font-semibold text-gold-bright lg:text-lg">
      Již brzy více referencí …
    </p>
  </div>
</div>

<script>
  const showMoreBtn = document.getElementById('projects-show-more');
  const moreProjects = document.getElementById('projects-more');
  const comingSoon = document.getElementById('projects-coming-soon');

  showMoreBtn?.addEventListener('click', () => {
    moreProjects?.classList.remove('hidden');
    showMoreBtn.classList.add('hidden');
    comingSoon?.classList.remove('hidden');
  });
</script>
