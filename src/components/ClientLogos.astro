---
const clients = [
  { src: '/images/client-hutchinson.png', alt: 'Hutchinson', class: 'h-10 lg:h-12' },
  { src: '/images/client-pilsner.png', alt: 'Pilsner Urquell', class: 'h-10 lg:h-12' },
  { src: '/images/client-skoda.png', alt: 'Škoda', class: 'h-10 lg:h-12' },
  { src: '/images/client-autoopat.png', alt: 'Auto Opat', class: 'h-10 lg:h-12' },
  { src: '/images/client-centralgroup.png', alt: 'Central Group', class: 'h-10 lg:h-12' },
  { src: '/images/client-xxxlutz.png', alt: 'XXXLutz', class: 'h-12 lg:h-14 max-w-[180px]' },
  { src: '/images/client-mobelix.png', alt: 'Möbelix', class: 'h-10 lg:h-12' },
];
---

<section class="py-10 lg:py-14 bg-white overflow-hidden" aria-label="Reference klientů">
  <div class="relative">
    <div class="marquee-track flex w-max items-center gap-12 lg:gap-20">
      {
        [...clients, ...clients].map((client, index) => (
          <img
            src={client.src}
            alt={index < clients.length ? client.alt : ''}
            class={`${client.class} w-auto object-contain shrink-0`}
            aria-hidden={index >= clients.length ? true : undefined}
            loading="lazy"
          />
        ))
      }
    </div>
  </div>
</section>
