---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="O nás | Prokat Invest"
  description="PROKAT invest — 25 let špičkových realizací v oblasti vzduchotechniky, vytápění, chlazení a ZTI od roku 1999."
>
  <Navbar />

  <main>
    <section class="section-watermark bg-surface py-16 lg:py-20">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
          <div>
            <h1 class="text-3xl sm:text-4xl lg:text-[58px] font-semibold text-navy tracking-tight mb-4">
              O nás
            </h1>
            <p class="text-lg md:text-[23px] font-medium text-navy/80">
              Plzeňská 1348/95, 150 00 Praha 5
            </p>
          </div>

          <p class="text-2xl sm:text-3xl lg:text-[42px] lg:leading-[1.2] font-semibold text-navy tracking-tight">
            <span class="text-gold">25 let</span> špičkových realizací a uznání
          </p>
        </div>
      </div>
    </section>

    <section class="bg-white py-12 lg:py-16 overflow-hidden">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 items-stretch">
          <div class="overflow-hidden">
            <img
              src="/images/about-building.jpg"
              alt="Budova PROKAT invest"
              class="h-full w-full object-cover min-h-[280px] lg:min-h-[480px]"
              width="980"
              height="551"
              loading="eager"
            />
          </div>

          <div class="relative bg-gold text-white p-8 lg:p-12 flex flex-col justify-center">
            <img
              src="/images/about-since-bg.png"
              alt=""
              class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none"
              aria-hidden="true"
            />
            <div class="relative space-y-4 text-base lg:text-lg leading-relaxed font-medium">
              <p>
                Realizujeme technologické celky včetně studie energetické hospodárnosti, projektu, realizace,
                záručního a pozáručního servisu včetně vzdáleného monitoringu.
              </p>
              <p>
                Společnost je držitelem ocenění <strong>AAA Excellent</strong> stability award — záruka finanční
                stability a spolehlivého partnerství.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="services-watermark bg-surface py-16 lg:py-24">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 mb-10 lg:mb-14">
          <p class="inline-flex items-center gap-2 rounded-full border border-gray-300 bg-white/80 px-4 py-2 text-sm font-medium text-navy md:text-base">
            <span class="h-1.5 w-1.5 rounded-full bg-gold" aria-hidden="true"></span>
            Naše cesta
          </p>
          <img
            src="/images/aaa-award.png"
            alt="AAA Czech Stability Award Excellent"
            class="h-16 lg:h-20 w-auto"
            width="200"
            height="80"
          />
        </div>

        <h2
          class="text-3xl sm:text-4xl lg:text-[58px] lg:leading-[1.1] font-semibold text-navy tracking-tight max-w-4xl mb-12 lg:mb-16"
        >
          Budujeme důvěru a kvalitu na základech <span class="text-gold">dlouholetých</span> inženýrských zkušeností.
        </h2>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-12 items-start">
          <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
            <img
              src="/images/about-director.png"
              alt="Ing. Vladimír Škrlant"
              class="w-full max-w-[280px] rounded-lg object-cover mb-4"
              width="305"
              height="304"
            />
            <p class="text-lg font-semibold text-navy">Ing. Vladimír Škrlant</p>
            <p class="text-base text-navy/70">Majitel &amp; ředitel</p>
          </div>

          <div>
            <h3 class="text-xl lg:text-2xl font-semibold text-navy mb-4">Náš příběh</h3>
            <div class="space-y-4 text-base lg:text-lg text-navy/80 leading-relaxed">
              <p>
                Začínali jsme jako tým technických specialistů s jasným cílem — dodávat spolehlivá a efektivní řešení
                v oblasti vzduchotechniky, vytápění a chlazení. Postupně jsme rozšířili portfolio o komplexní služby
                včetně měření, regulace a fotovoltaiky.
              </p>
              <p>
                Dnes jsme stabilním partnerem pro průmyslové i komerční projekty po celé České republice. Naším
                cílem zůstává kvalita realizace, dlouhodobá spolupráce a provozní úspory pro každého zákazníka.
              </p>
            </div>
          </div>

          <div>
            <h3 class="text-xl lg:text-2xl font-semibold text-navy mb-4">Naše odborné kompetence</h3>
            <ul class="space-y-3 mb-8">
              {
                ['Vzduchotechnika', 'Topné zdroje', 'Chlazení', 'Fotovoltaika'].map((item) => (
                  <li class="flex items-center gap-3 text-base lg:text-lg font-medium text-navy">
                    <img src="/icons/arrow.svg" alt="" class="h-3 w-4 rotate-180 shrink-0" aria-hidden="true" />
                    {item}
                  </li>
                ))
              }
            </ul>

            <a
              href="/projekty"
              class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-1.5 text-white text-sm font-medium h-[52px] hover:opacity-95 transition-opacity"
            >
              <span>Zobrazit naše realizace</span>
              <span
                class="btn-gradient-icon flex h-10 w-10 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
              >
                <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
