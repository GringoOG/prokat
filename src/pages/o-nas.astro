---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="O nás | Prokat Invest"
  description="PROKAT invest — 25 let špičkových realizací v oblasti vzduchotechniky, vytápění, chlazení a ZTI od roku 1999."
>
  <div class="section-watermark bg-surface relative">
    <Navbar />

    <section class="pb-12 pt-8 lg:pb-16 lg:pt-28">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <div class="text-center">
          <h1 class="text-3xl font-semibold leading-none tracking-tight text-navy sm:text-4xl lg:text-[58px]">
            O nás
          </h1>
          <p class="mt-2 text-lg font-medium leading-snug text-navy/80 md:text-[23px]">
            Plzeňská 1348/95, 150 00 Praha 5
          </p>
        </div>

        <p
          class="mt-8 max-w-md text-left text-xl font-semibold leading-none tracking-tight text-navy sm:text-2xl lg:mt-10 lg:text-[42px]"
        >
          <span class="text-gold">25 let</span> špičkových<br />
          realizací a uznání
        </p>
      </div>
    </section>
  </div>

  <main>
    <section class="overflow-hidden bg-white pb-12 lg:pb-16">
      <div class="relative grid grid-cols-1 lg:grid-cols-2">
        <div class="overflow-hidden">
          <img
            src="/images/about-building.jpg"
            alt="Budova PROKAT invest"
            class="h-full w-full min-h-[300px] object-cover lg:min-h-[520px]"
            width="980"
            height="551"
            loading="eager"
          />
        </div>

        <div class="relative flex min-h-[360px] items-center overflow-hidden bg-navy lg:min-h-[520px]">
          <div
            class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-28 bg-gradient-to-r from-gold/80 via-gold/25 to-transparent sm:w-36 lg:w-44"
            aria-hidden="true"
          ></div>
          <img
            src="/images/about-since-bg.png"
            alt=""
            class="pointer-events-none absolute inset-0 z-[2] h-full w-full object-cover opacity-[0.08]"
            aria-hidden="true"
          />

          <div class="relative z-10 space-y-4 px-8 py-14 pb-28 text-base font-medium leading-relaxed text-white sm:px-10 lg:px-14 lg:py-16 lg:pb-32 lg:text-lg">
            <p>
              Realizujeme technologické celky včetně studie energetické hospodárnosti, projektu, realizace,
              záručního a pozáručního servisu včetně vzdáleného monitoringu.
            </p>
            <p>
              Společnost je držitelem ocenění <strong>AAA Excellent</strong> stability award — záruka finanční
              stability a spolehlivého partnerství.
            </p>
          </div>
        </div>

        <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-20 overflow-hidden" aria-hidden="true">
          <div class="since-marquee-track flex w-max items-center">
            {
              Array.from({ length: 2 }).map(() => (
                <p class="since-marquee-text">
                  SINCE - 1999 &nbsp; SINCE - 1999 &nbsp; SINCE - 1999 &nbsp; SINCE - 1999 &nbsp;
                </p>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="services-watermark bg-surface py-16 lg:py-24">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <p
          class="mx-auto mb-8 inline-flex w-fit items-center gap-2.5 rounded-full border border-gray-300 bg-white/80 px-4 py-2 text-sm font-medium text-navy md:text-base lg:mx-0"
        >
          <span class="h-2 w-2 shrink-0 rounded-[2px] bg-gold-bright" aria-hidden="true"></span>
          Naše cesta
        </p>

        <div class="mb-12 flex flex-col items-center gap-8 lg:mb-16 lg:flex-row lg:items-start lg:gap-10 xl:gap-14">
          <img
            src="/images/aaa-award-vertical.png"
            alt="AAA Czech Stability Award Excellent"
            class="mx-auto h-[184px] w-[135px] shrink-0 object-contain lg:mx-0"
            width="135"
            height="184"
          />
          <h2
            class="max-w-4xl text-center text-3xl font-semibold leading-[1.1] tracking-tight text-navy sm:text-4xl lg:pt-1 lg:text-left lg:text-[58px]"
          >
            Budujeme důvěru a kvalitu na základech <span class="text-gold">dlouholetých</span> inženýrských
            zkušeností.
          </h2>
        </div>

        <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-[minmax(0,305px)_1fr] lg:gap-12 xl:gap-16">
          <div class="relative mx-auto w-full max-w-[305px] overflow-hidden rounded-2xl lg:mx-0">
            <img
              src="/images/about-director.png"
              alt="Ing. Vladimír Škrlant"
              class="aspect-[305/420] w-full object-cover"
              width="305"
              height="420"
            />
            <div
              class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/75 via-black/45 to-transparent px-6 pb-6 pt-16"
            >
              <p class="text-sm font-medium text-white/90 sm:text-base">Ing. Vladimír Škrlant</p>
              <p class="mt-1 text-xl font-semibold leading-tight text-white sm:text-2xl">Majitel &amp; ředitel</p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-8 lg:gap-12">
            <div>
              <h3 class="mb-4 text-xl font-semibold text-navy lg:text-2xl">Náš příběh</h3>
              <div class="space-y-4 text-base leading-relaxed text-navy/80 lg:text-lg">
                <p>
                  Začínali jsme jako tým technických specialistů s jasným cílem — dodávat spolehlivá a efektivní
                  řešení v oblasti vzduchotechniky, vytápění a chlazení. Postupně jsme rozšířili portfolio o
                  komplexní služby včetně měření, regulace a fotovoltaiky.
                </p>
                <p>
                  Dnes jsme stabilním partnerem pro průmyslové i komerční projekty po celé České republice. Naším
                  cílem zůstává kvalita realizace, dlouhodobá spolupráce a provozní úspory pro každého zákazníka.
                </p>
              </div>
            </div>

            <div class="flex flex-col">
              <h3 class="mb-4 text-xl font-semibold text-navy lg:text-2xl">Naše odborné kompetence</h3>
              <ul class="mb-8 divide-y divide-gray-200 border-t border-gray-200">
                {
                  ['Vzduchotechnika', 'Topné zdroje', 'Chlazení', 'Fotovoltaika'].map((item) => (
                    <li class="flex items-center justify-between gap-4 py-4 text-base font-medium text-navy lg:text-lg">
                      <span>{item}</span>
                      <svg
                        class="h-3 w-4 shrink-0 text-gold-bright"
                        viewBox="0 0 16 12"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                        aria-hidden="true"
                      >
                        <path
                          d="m14.425 6-5-5m5 5-5 5m5-5H1.575"
                          stroke="currentColor"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"></path>
                      </svg>
                    </li>
                  ))
                }
              </ul>

              <a
                href="/projekty"
                class="btn-gradient mt-auto inline-flex min-h-[52px] h-auto w-full items-center justify-between gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl py-3 pl-[18px] pr-1.5 text-sm font-medium text-white hover:opacity-95 transition-opacity sm:w-auto sm:justify-start"
              >
                <span>Zobrazit naše realizace.</span>
                <span
                  class="btn-gradient-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
                >
                  <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
