---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
---

<Layout
  title="Projekty | Prokat Invest"
  description="Naše projekty — reference realizací pro Škoda Auto, Pilsner Urquell, Letiště Václava Havla, Hotel Marriott a další."
>
  <Navbar />

  <main>
    <section class="section-watermark bg-surface py-16 lg:py-24">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <h1 class="text-3xl sm:text-4xl lg:text-[58px] font-semibold text-navy tracking-tight text-center mb-12 lg:mb-16">
          Naše projekty
        </h1>

        <ProjectsGrid />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
