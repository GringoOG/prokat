---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import ServicesCta from '../components/ServicesCta.astro';
import FaqSection from '../components/FaqSection.astro';
---

<Layout
  title="Služby | Prokat Invest"
  description="Naše služby — vzduchotechnika, topné zdroje, chlazení a fotovoltaika. Kompletní realizace od projektu po servis."
>
  <div class="services-watermark bg-surface relative">
    <Navbar />

    <section class="pb-16 pt-8 lg:pb-24 lg:pt-28">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <h1 class="text-3xl sm:text-4xl lg:text-[58px] font-semibold text-navy tracking-tight text-center mb-12 lg:mb-16">
          Naše služby
        </h1>

        <ServicesGrid />
      </div>
    </section>
  </div>

  <main>
    <ServicesCta />
    <FaqSection />
  </main>

  <Footer />
</Layout>
