---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ClientLogos from '../components/ClientLogos.astro';
---

<Layout>
  <Navbar />

  <main>
    <!-- HERO -->
    <section class="section-watermark bg-surface">
      <div class="mx-auto max-w-site px-6 lg:px-10 pt-8 pb-0">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
          <div class="space-y-6">
            <p
              class="inline-flex items-center gap-2 rounded-full border border-gray-300 bg-white/80 px-4 py-2 text-sm font-medium text-navy md:text-base"
            >
              <span class="h-1.5 w-1.5 rounded-full bg-gold" aria-hidden="true"></span>
              Váš spolehlivý partner pro technologické celky
            </p>

            <h1 class="text-4xl sm:text-5xl lg:text-[72px] lg:leading-[1.05] font-semibold text-navy tracking-tight">
              Od <span class="text-gold">návrhu</span> až po spuštění zdroje.
            </h1>

            <p class="text-lg md:text-[23px] font-medium leading-snug">
              Provozní úspory 10-20% nákladů pomocí AI managmentu.
            </p>

            <p class="text-lg md:text-[23px] font-medium leading-relaxed text-black/90 max-w-xl">
              // Od roku 1999 //<br />
              Jsme spolehlivým partnerem pro systémová řešení vzduchotechniky, vytápění, chlazení a ZTI, včetně
              měření a regulace.
            </p>
          </div>

          <div class="flex flex-col items-start lg:items-end gap-8">
            <a
              href="/sluzby"
              class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-1.5 text-white text-sm font-medium h-[52px] hover:opacity-95 transition-opacity w-full sm:w-auto justify-between sm:justify-start"
            >
              <span>Prozkoumejte naše služby</span>
              <span
                class="btn-gradient-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
              >
                <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
              </span>
            </a>
          </div>
        </div>
      </div>

      <div class="mt-10 lg:mt-16 w-full">
        <img
          src="/images/hero-photo.png"
          alt="Průmyslové vzduchotechnické zařízení"
          class="w-full h-auto object-cover max-h-[420px] lg:max-h-none"
          width="1920"
          height="800"
          loading="eager"
        />
      </div>

      <div class="text-center py-6">
        <a
          href="/o-nas"
          class="text-xs font-semibold tracking-[0.25em] text-navy/60 uppercase hover:text-navy transition-colors"
        >
          Zjistit více
        </a>
      </div>
    </section>

    <!-- RYCHLÝ PŘEHLED -->
    <section class="bg-surface py-16 lg:py-24">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <div class="text-center mb-12">
          <p class="inline-flex items-center gap-2 text-sm md:text-[24px] font-medium text-navy mb-4">
            <span class="h-1.5 w-1.5 rounded-full bg-gold" aria-hidden="true"></span>
            Rychlý přehled
          </p>
          <h2 class="text-3xl sm:text-4xl lg:text-[58px] lg:leading-[1.1] font-semibold text-navy tracking-tight max-w-4xl mx-auto">
            Technologické celky s důrazem na <span class="text-gold">provozní úspory</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
          <div class="bg-white rounded-2xl p-8 text-center shadow-sm border border-gray-100">
            <p class="text-4xl lg:text-5xl font-semibold text-stat">1500<span class="text-navy">+</span></p>
            <p class="text-base lg:text-lg font-medium text-navy/80 mt-2">Realizovaných technologických celků</p>
          </div>
          <div class="bg-white rounded-2xl p-8 text-center shadow-sm border border-gray-100">
            <p class="text-4xl lg:text-5xl font-semibold text-navy">4.9<span class="text-lg text-navy/60">/5.0</span></p>
            <p class="text-base lg:text-lg font-medium text-navy/80 mt-2">Hodnocení kvality realizací</p>
          </div>
          <div class="bg-white rounded-2xl p-8 text-center shadow-sm border border-gray-100">
            <p class="text-4xl lg:text-5xl font-semibold text-gold">25+</p>
            <p class="text-base lg:text-lg font-medium text-navy/80 mt-2">Let zkušeností na trhu</p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <a
            href="/sluzby"
            class="group bg-white rounded-2xl p-6 border border-gray-100 hover:border-gold/40 hover:shadow-md transition-all"
          >
            <img src="/images/service-hvac.jpg" alt="" class="rounded-lg w-full h-24 object-cover mb-4" />
            <h3 class="text-lg font-semibold text-navy group-hover:text-gold transition-colors">Vzduchotechnika</h3>
          </a>
          <a
            href="/sluzby"
            class="group bg-white rounded-2xl p-6 border border-gray-100 hover:border-gold/40 hover:shadow-md transition-all"
          >
            <img src="/images/service-heating.jpg" alt="" class="rounded-lg w-full h-24 object-cover mb-4" />
            <h3 class="text-lg font-semibold text-navy group-hover:text-gold transition-colors">Topné zdroje</h3>
          </a>
          <a
            href="/sluzby"
            class="group bg-white rounded-2xl p-6 border border-gray-100 hover:border-gold/40 hover:shadow-md transition-all"
          >
            <img src="/images/service-cooling.png" alt="" class="rounded-lg w-full h-24 object-cover mb-4" />
            <h3 class="text-lg font-semibold text-navy group-hover:text-gold transition-colors">Chlazení</h3>
          </a>
          <a
            href="/sluzby"
            class="group bg-white rounded-2xl p-6 border border-gray-100 hover:border-gold/40 hover:shadow-md transition-all"
          >
            <img src="/images/service-solar.png" alt="" class="rounded-lg w-full h-24 object-cover mb-4" />
            <h3 class="text-lg font-semibold text-navy group-hover:text-gold transition-colors">Fotovoltaika</h3>
          </a>
        </div>

        <div class="flex flex-wrap justify-center gap-4 mt-10">
          <a
            href="/o-nas"
            class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-1.5 text-white text-sm font-medium h-[52px] hover:opacity-95 transition-opacity"
          >
            <span>Více o společnosti</span>
            <span
              class="btn-gradient-icon flex h-10 w-10 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
            >
              <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
            </span>
          </a>
          <a
            href="/kontakt"
            class="inline-flex items-center gap-3 rounded-full border border-navy/20 bg-white pl-6 pr-6 py-3 text-navy text-sm font-semibold hover:bg-gray-50 transition-colors"
          >
            Kontaktujte nás
          </a>
        </div>
      </div>
    </section>

    <!-- REFERENCE -->
    <ClientLogos />
  </main>

  <Footer />
</Layout>
