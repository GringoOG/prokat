---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ClientLogos from '../components/ClientLogos.astro';
import CtaBanner from '../components/CtaBanner.astro';
import ServiceList from '../components/ServiceList.astro';
---

<Layout>
  <div class="section-watermark bg-surface relative">
    <Navbar transparent />

    <!-- HERO -->
    <section class="pb-0">
        <div class="mx-auto max-w-site px-6 lg:px-10 pb-0 pt-8 lg:pt-28">
          <div class="flex flex-col gap-10 text-center lg:grid lg:grid-cols-[minmax(0,1fr)_auto] lg:items-start lg:gap-x-16 lg:gap-y-6 lg:text-left xl:gap-x-16">
            <p
              class="mx-auto inline-flex max-w-full flex-wrap items-center gap-2.5 rounded-full border border-gray-300 bg-white/80 px-4 py-2 text-xs font-medium text-navy sm:text-sm md:text-base lg:col-start-1 lg:row-start-1 lg:mx-0"
            >
              <span class="h-2 w-2 shrink-0 rounded-[2px] bg-gold-bright" aria-hidden="true"></span>
              Váš spolehlivý partner pro technologické celky
            </p>

            <h1
              class="text-4xl sm:text-5xl lg:col-start-1 lg:row-start-2 lg:text-[72px] lg:leading-[1.05] font-semibold text-navy tracking-tight"
            >
              Od <span class="text-gold-bright">návrhu</span> až po spuštění zdroje.
            </h1>

            <p class="text-lg md:text-[23px] font-medium leading-snug text-navy lg:col-start-1 lg:row-start-3">
              Provozní úspory 10-20% nákladů pomocí AI managmentu.
            </p>

            <p class="mx-auto max-w-xl text-lg md:text-[23px] font-medium leading-relaxed text-navy lg:col-start-1 lg:row-start-4 lg:mx-0">
              // Od roku 1999 //<br />
              Jsme spolehlivým partnerem pro systémová řešení vzduchotechniky, vytápění, chlazení a ZTI, včetně
              měření a regulace.
            </p>

            <div
              class="mx-auto flex w-full max-w-md shrink-0 flex-col items-center gap-8 lg:col-start-2 lg:row-start-2 lg:row-span-3 lg:mx-0 lg:max-w-lg lg:self-start"
            >
              <address class="not-italic space-y-0.5 text-base font-medium leading-relaxed text-navy sm:text-[21px]">
                <p>Sídlo společnosti:</p>
                <p class="font-semibold">PROKAT invest s.r.o.</p>
                <p>Plzeňská 1348/95, Praha 5</p>
                <p>IČ: 25238876, DIČ: CZ25238876</p>
                <p>Datová schránka: ns3u7ke</p>
                <p>Společnost je zapsaná v obchodním rejstříku:</p>
                <p>Městský soud v Praze, oddíl C, vložka 350481.</p>
              </address>

              <a
                href="/sluzby"
                class="btn-gradient inline-flex min-h-[52px] h-auto w-full items-center justify-between gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl py-3 pl-[18px] pr-1.5 text-sm font-medium text-white hover:opacity-95 transition-opacity sm:w-auto sm:justify-start lg:justify-center"
              >
                <span>Prozkoumejte naše služby</span>
                <span
                  class="btn-gradient-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
                >
                  <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
                </span>
              </a>
            </div>
          </div>
        </div>

        <div class="py-8 text-center lg:py-12">
          <a
            href="#technologie"
            class="text-[11px] font-semibold uppercase tracking-[0.3em] text-navy/50 hover:text-navy transition-colors"
          >
            Zjistit více
          </a>
        </div>
      </section>
  </div>

  <main>
    <section id="technologie" class="relative overflow-hidden min-h-[380px] sm:min-h-[460px] lg:min-h-[560px]">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        class="absolute inset-0 h-full w-full object-cover object-center"
        aria-label="Průmyslové vzduchotechnické zařízení"
      >
        <source src="/videos/vzt.webm" type="video/webm" />
      </video>
      <div class="absolute inset-0 bg-black/25"></div>
      <div class="absolute inset-0 z-10 flex items-center justify-center px-6 lg:px-10">
        <h2
          class="text-center text-3xl sm:text-4xl lg:text-[58px] lg:leading-[1.15] font-semibold text-white tracking-tight max-w-4xl drop-shadow-sm"
        >
          Nejnovější technologie.<br />
          Prověřeno v <span class="text-gold-bright">praxi.</span><br />
          Provozně hospodárné systémy řízeny AI.
        </h2>
      </div>
    </section>

    <!-- STATISTIKY -->
    <section class="relative bg-gradient-to-b from-[#0d0d1a] via-[#1a1520] to-[#8c6c3c] py-20 lg:py-28 overflow-hidden">
      <div class="mx-auto max-w-site px-6 lg:px-10 text-center">
        <p class="text-lg md:text-[23px] font-medium text-white/90 max-w-3xl mx-auto mb-8">
          Realizujeme technologické celky včetně studie energetické hospodárnosti, projektu, realizace, záručního a
          pozáručních servisu
        </p>

        <a
          href="/o-nas"
          class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-3 text-white text-sm font-medium min-h-[52px] h-auto hover:opacity-95 transition-opacity mb-16 w-full sm:w-auto justify-center sm:justify-start"
        >
          <span>Více o naší společnosti</span>
          <span
            class="btn-gradient-icon flex h-10 w-10 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
          >
            <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
          </span>
        </a>

        <div class="relative mx-auto w-full max-w-[760px] xl:max-w-[820px]">
          <!-- Mobil: přehledný stack -->
          <div class="flex flex-col items-center gap-10 lg:hidden">
            <div
              class="bg-white rounded-full w-[min(100%,320px)] aspect-square flex flex-col items-center justify-center shadow-2xl px-8 py-6"
            >
              <img src="/images/logo.png" alt="" class="h-8 mb-3 opacity-80" aria-hidden="true" />
              <p class="text-5xl font-semibold text-stat leading-none">
                1500<span class="text-navy">+</span>
              </p>
              <p class="mt-3 text-center text-base font-medium leading-snug text-navy">
                Realizovaných<br />technologických celků.
              </p>
              <div class="mt-3 flex items-center gap-1">
                <span class="text-xl font-semibold text-navy">4.9</span>
                <span class="text-base font-medium text-navy">/5.0</span>
                <img src="/icons/stars.svg" alt="Hodnocení 4.9 z 5" class="ml-2 h-3.5" />
              </div>
            </div>
            <div
              class="h-[220px] w-[220px] shrink-0 overflow-hidden rounded-full border-4 border-white/20 shadow-xl"
            >
              <img
                src="/images/about-industrial.jpg"
                alt="Průmyslové technologie"
                class="h-full w-full object-cover"
              />
            </div>
            <div
              class="flex aspect-square w-[min(100%,300px)] flex-col items-center justify-center rounded-full border border-black/30 bg-[linear-gradient(180deg,#101029_0%,#1a1528_38%,#6b5428_78%,#a67c37_100%)] px-8 py-6 shadow-2xl"
            >
              <p class="text-sm font-medium text-white/80">// 1999-2026 //</p>
              <p class="mt-2 text-5xl font-semibold leading-none text-gold-bright">25+</p>
              <p class="mt-4 text-center text-sm leading-relaxed text-white/90">
                Garantujeme špičkovou kvalitu realizací již od samého začátku.
              </p>
              <img
                src="/images/kotel.png"
                alt=""
                class="mt-4 h-16 w-auto shrink-0"
                width="422"
                height="482"
                aria-hidden="true"
              />
            </div>
          </div>

          <!-- Desktop: trojúhelníková kompozice (2 nahoře, 1 dole uprostřed) -->
          <div class="relative mx-auto hidden h-[660px] w-full max-w-[700px] lg:block xl:h-[700px] xl:max-w-[760px]">
            <div
              class="absolute left-0 top-0 z-30 flex h-[340px] w-[340px] flex-col items-center justify-center rounded-full bg-white px-8 shadow-2xl xl:h-[380px] xl:w-[380px]"
            >
              <img src="/images/logo.png" alt="" class="mb-3 h-8 opacity-80" aria-hidden="true" />
              <p class="text-[64px] font-semibold leading-none text-stat xl:text-[72px]">
                1500<span class="text-navy">+</span>
              </p>
              <p class="mt-3 max-w-[250px] text-center text-[20px] font-medium leading-snug text-navy xl:text-[24px]">
                Realizovaných<br />technologických celků.
              </p>
              <div class="mt-3 flex items-center gap-1">
                <span class="text-[26px] font-semibold text-navy xl:text-[28px]">4.9</span>
                <span class="text-[22px] font-medium text-navy xl:text-[26px]">/5.0</span>
                <img src="/icons/stars.svg" alt="Hodnocení 4.9 z 5" class="ml-2 h-3.5" />
              </div>
            </div>

            <div
              class="absolute right-0 top-0 z-20 h-[340px] w-[340px] overflow-hidden rounded-full border-4 border-white/20 shadow-2xl xl:h-[380px] xl:w-[380px]"
            >
              <img
                src="/images/about-industrial.jpg"
                alt="Průmyslové technologie"
                class="h-full w-full object-cover"
              />
            </div>

            <div
              class="absolute left-1/2 top-[300px] z-20 flex h-[320px] w-[320px] -translate-x-1/2 flex-col items-center justify-center rounded-full border border-black/30 bg-[linear-gradient(180deg,#101029_0%,#1a1528_38%,#6b5428_78%,#a67c37_100%)] px-8 shadow-2xl xl:top-[320px] xl:h-[340px] xl:w-[340px]"
            >
              <p class="text-lg font-medium text-white/80 xl:text-xl">// 1999-2026 //</p>
              <p class="mt-2 text-[60px] font-semibold leading-none text-gold-bright xl:text-[72px]">25+</p>
              <p class="mt-3 max-w-[240px] text-center text-sm leading-relaxed text-white/90 xl:text-base">
                Garantujeme špičkovou kvalitu realizací již od samého začátku.
              </p>
              <img
                src="/images/kotel.png"
                alt=""
                class="mt-2 h-16 w-auto shrink-0 xl:mt-3 xl:h-20"
                width="422"
                height="482"
                aria-hidden="true"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SLUŽBY -->
    <section class="services-watermark bg-surface py-16 lg:py-24">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
          <div class="space-y-4 max-w-3xl">
            <p class="inline-flex items-center gap-2 text-sm md:text-[24px] font-medium text-navy">
              <span class="h-1.5 w-1.5 rounded-full bg-gold" aria-hidden="true"></span>
              Co děláme
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-[58px] lg:leading-[1.1] font-semibold text-navy tracking-tight">
              Flexibilní řešení pro <span class="text-gold">široký</span> rozsah použití TZB systémů
            </h2>
          </div>
          <a
            href="/sluzby"
            class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-3 text-white text-sm font-medium min-h-[52px] h-auto hover:opacity-95 transition-opacity shrink-0 self-stretch sm:self-start lg:self-auto w-full sm:w-auto justify-between sm:justify-start"
          >
            <span>Prozkoumejte naše služby</span>
            <span
              class="btn-gradient-icon flex h-10 w-10 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
            >
              <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
            </span>
          </a>
        </div>

        <ServiceList />
      </div>
    </section>

    <CtaBanner />
    <ClientLogos />
  </main>

  <Footer />
</Layout>
