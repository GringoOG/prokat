---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ClientLogos from '../components/ClientLogos.astro';
import CtaBanner from '../components/CtaBanner.astro';
import ServiceList from '../components/ServiceList.astro';
---

<Layout>
  <Navbar />

  <main>
    <!-- HERO -->
    <section class="section-watermark bg-surface">
      <div class="mx-auto max-w-site px-6 lg:px-10 pt-6 lg:pt-8 pb-0">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-start">
          <div class="space-y-5 lg:space-y-6 lg:pt-2">
            <p
              class="inline-flex items-center gap-2.5 rounded-full border border-gray-300 bg-white/80 px-4 py-2 text-sm font-medium text-navy md:text-base"
            >
              <span class="h-2 w-2 shrink-0 rounded-[2px] bg-gold-bright" aria-hidden="true"></span>
              Váš spolehlivý partner pro technologické celky
            </p>

            <h1 class="text-4xl sm:text-5xl lg:text-[72px] lg:leading-[1.05] font-semibold text-navy tracking-tight">
              Od <span class="text-gold-bright">návrhu</span> až po spuštění zdroje.
            </h1>

            <p class="text-lg md:text-[23px] font-medium leading-snug text-navy">
              Provozní úspory 10-20% nákladů pomocí AI managmentu.
            </p>

            <p class="text-lg md:text-[23px] font-medium leading-relaxed text-navy max-w-xl">
              // Od roku 1999 //<br />
              Jsme spolehlivým partnerem pro systémová řešení vzduchotechniky, vytápění, chlazení a ZTI, včetně
              měření a regulace.
            </p>
          </div>

          <div class="flex flex-col items-start lg:items-end gap-8 lg:pt-2">
            <address class="not-italic text-base sm:text-[21px] font-medium leading-relaxed text-navy lg:text-right space-y-0.5">
              <p>Sídlo společnosti:</p>
              <p class="font-semibold">PROKAT invest s.r.o.</p>
              <p>Plzeňská 1348/95, Praha 5</p>
              <p>IČ: 25238876, DIČ: CZ25238876</p>
              <p>Datová schránka: ns3u7ke</p>
              <p>Společnost je zapsaná v obchodním rejstříku:</p>
              <p>Městský soud v Praze, oddíl C, vložka 350481.</p>
            </address>

            <a
              href="/sluzby"
              class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-1.5 text-white text-sm font-medium h-[52px] hover:opacity-95 transition-opacity w-full sm:w-auto justify-between sm:justify-start"
            >
              <span>Prozkoumejte naše služby</span>
              <span
                class="btn-gradient-icon flex h-10 w-10 shrink-0 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
              >
                <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
              </span>
            </a>
          </div>
        </div>
      </div>

      <div class="text-center py-8 lg:py-12">
        <a
          href="#technologie"
          class="text-[11px] font-semibold tracking-[0.3em] text-navy/50 uppercase hover:text-navy transition-colors"
        >
          Zjistit více
        </a>
      </div>
    </section>

    <!-- TECHNOLOGIE + VZT video -->
    <section id="technologie" class="relative overflow-hidden min-h-[380px] sm:min-h-[460px] lg:min-h-[560px]">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        class="absolute inset-0 h-full w-full object-cover object-center"
        aria-label="Průmyslové vzduchotechnické zařízení"
      >
        <source src="/videos/vzt.webm" type="video/webm" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-black/35 via-black/10 to-transparent"></div>
      <div class="relative mx-auto max-w-site px-6 lg:px-10 py-16 sm:py-20 lg:py-28 text-left">
        <h2
          class="text-3xl sm:text-4xl lg:text-[58px] lg:leading-[1.15] font-semibold text-white tracking-tight max-w-3xl drop-shadow-sm"
        >
          Nejnovější technologie.<br />
          Prověřeno v <span class="text-gold-bright">praxi.</span><br />
          Provozně hospodárné systémy řízeny AI.
        </h2>
      </div>
    </section>

    <!-- STATISTIKY -->
    <section class="relative bg-gradient-to-b from-[#0d0d1a] via-[#1a1520] to-[#8c6c3c] py-20 lg:py-28 overflow-hidden">
      <div class="mx-auto max-w-site px-6 lg:px-10 text-center">
        <p class="text-lg md:text-[23px] font-medium text-white/90 max-w-3xl mx-auto mb-8">
          Realizujeme technologické celky včetně studie energetické hospodárnosti, projektu, realizace, záručního a
          pozáručních servisu
        </p>

        <a
          href="/o-nas"
          class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-1.5 text-white text-sm font-medium h-[52px] hover:opacity-95 transition-opacity mb-16"
        >
          <span>Více o naší společnosti</span>
          <span
            class="btn-gradient-icon flex h-10 w-10 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
          >
            <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
          </span>
        </a>

        <div class="relative mx-auto w-full max-w-[920px] lg:min-h-[560px]">
          <!-- Mobil: přehledný stack -->
          <div class="flex flex-col items-center gap-8 lg:hidden">
            <div
              class="bg-white rounded-full w-[min(100%,340px)] aspect-square flex flex-col items-center justify-center shadow-2xl px-6"
            >
              <img src="/images/logo.png" alt="" class="h-8 mb-4 opacity-80" aria-hidden="true" />
              <p class="text-5xl font-semibold text-stat leading-none">
                1500<span class="text-navy">+</span>
              </p>
              <p class="text-base font-medium text-navy mt-2 text-center">
                Realizovaných technologických celků.
              </p>
              <div class="flex items-center gap-1 mt-3">
                <span class="text-xl font-semibold text-navy">4.9</span>
                <span class="text-base font-medium text-navy">/5.0</span>
                <img src="/icons/stars.svg" alt="Hodnocení 4.9 z 5" class="h-3.5 ml-2" />
              </div>
            </div>
            <div
              class="rounded-full overflow-hidden w-[220px] h-[220px] border-4 border-white/20 shadow-xl shrink-0"
            >
              <img
                src="/images/about-industrial.jpg"
                alt="Průmyslové technologie"
                class="w-full h-full object-cover"
              />
            </div>
            <div
              class="bg-navy rounded-full w-[min(100%,300px)] aspect-square flex flex-col items-center justify-center border border-white/10 shadow-2xl px-6"
            >
              <p class="text-sm font-medium text-white/80">// 1999-2026 //</p>
              <p class="text-5xl font-semibold text-gold-bright leading-none mt-2">25+</p>
              <p class="text-sm text-white/80 mt-4 text-center leading-relaxed">
                Garantujeme špičkovou kvalitu realizací již od samého začátku.
              </p>
            </div>
          </div>

          <!-- Desktop: překrývající se kompozice -->
          <div class="hidden lg:block relative h-[560px]">
            <div
              class="absolute left-0 top-0 z-10 bg-white rounded-full w-[380px] h-[380px] flex flex-col items-center justify-center shadow-2xl"
            >
              <img src="/images/logo.png" alt="" class="h-8 mb-4 opacity-80" aria-hidden="true" />
              <p class="text-[72px] font-semibold text-stat leading-none">
                1500<span class="text-navy">+</span>
              </p>
              <p class="text-[26px] font-medium text-navy mt-2 px-6 text-center">
                Realizovaných technologických celků.
              </p>
              <div class="flex items-center gap-1 mt-3">
                <span class="text-[28px] font-semibold text-navy">4.9</span>
                <span class="text-[26px] font-medium text-navy">/5.0</span>
                <img src="/icons/stars.svg" alt="Hodnocení 4.9 z 5" class="h-3.5 ml-2" />
              </div>
            </div>

            <div
              class="absolute left-[48%] top-1/2 z-20 -translate-x-1/2 -translate-y-[42%] rounded-full overflow-hidden w-[300px] h-[300px] border-4 border-white/25 shadow-2xl"
            >
              <img
                src="/images/about-industrial.jpg"
                alt="Průmyslové technologie"
                class="w-full h-full object-cover"
              />
            </div>

            <div
              class="absolute left-[6%] bottom-0 z-10 bg-navy rounded-full w-[340px] h-[340px] flex flex-col items-center justify-center border border-white/10 shadow-2xl"
            >
              <p class="text-[23px] font-medium text-white/80">// 1999-2026 //</p>
              <p class="text-[72px] font-semibold text-gold-bright leading-none mt-2">25+</p>
              <p class="text-lg text-white/80 mt-4 px-8 text-center leading-relaxed">
                Garantujeme špičkovou kvalitu realizací již od samého začátku.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SLUŽBY -->
    <section class="services-watermark bg-surface py-16 lg:py-24">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
          <div class="space-y-4 max-w-3xl">
            <p class="inline-flex items-center gap-2 text-sm md:text-[24px] font-medium text-navy">
              <span class="h-1.5 w-1.5 rounded-full bg-gold" aria-hidden="true"></span>
              Co děláme
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-[58px] lg:leading-[1.1] font-semibold text-navy tracking-tight">
              Flexibilní řešení pro <span class="text-gold">široký</span> rozsah použití TZB systémů
            </h2>
          </div>
          <a
            href="/sluzby"
            class="btn-gradient inline-flex items-center gap-3 rounded-tl rounded-tr rounded-br-[14px] rounded-bl pl-[18px] pr-1.5 py-1.5 text-white text-sm font-medium h-[52px] hover:opacity-95 transition-opacity shrink-0 self-start lg:self-auto"
          >
            <span>Prozkoumejte naše služby</span>
            <span
              class="btn-gradient-icon flex h-10 w-10 items-center justify-center rounded-tl rounded-tr rounded-br-[10px] rounded-bl"
            >
              <img src="/icons/arrow.svg" alt="" class="h-3 w-4" />
            </span>
          </a>
        </div>

        <ServiceList />
      </div>
    </section>

    <CtaBanner />
    <ClientLogos />
  </main>

  <Footer />
</Layout>
