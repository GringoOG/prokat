---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ClientLogos from '../components/ClientLogos.astro';
import ContactCompanyInfo from '../components/ContactCompanyInfo.astro';
import ContactPersons from '../components/ContactPersons.astro';
---

<Layout
  title="Kontakt | Prokat Invest"
  description="Kontakty PROKAT invest s.r.o. — sídlo v Praze, provozní střediska a kompletní seznam kontaktních osob."
>
  <Navbar />

  <main>
    <section class="section-watermark bg-surface py-16 lg:py-24">
      <div class="mx-auto max-w-site px-6 lg:px-10">
        <h1 class="text-3xl sm:text-4xl lg:text-[58px] font-semibold text-navy tracking-tight text-center mb-12 lg:mb-16">
          Kontakty
        </h1>

        <ContactCompanyInfo />
      </div>
    </section>

    <ContactPersons />
    <ClientLogos />
  </main>

  <Footer />
</Layout>
